{
  "name": "airoost",
  "version": "0.1.0",
  "description": "VLC for AI models — download and run open-source AI models locally with zero setup",
  "main": "out/main/index.js",
  "author": "joym-gits",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite build && node scripts/fix-esm.mjs && env -u ELECTRON_RUN_AS_NODE electron .",
    "build": "electron-vite build && node scripts/fix-esm.mjs",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "node-llama-cpp": "^3.18.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^35.7.5",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.airoost.app",
    "productName": "Airoost",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
